# Upstash Redis (required)
# Create free account at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# API authentication (required - endpoints fail closed without it)
# Generate with: openssl rand -hex 32
API_KEY=your_api_key_here

# MCP authentication (required - endpoint fails closed without it)
# Generate with: openssl rand -hex 16
MCP_SECRET=your_mcp_secret_here

# Timezone for date calculations (optional, defaults to UTC)
# Vercel functions run in UTC; set this to your IANA timezone so "today"/
# "yesterday" match your local calendar day, e.g. America/Sao_Paulo
TIMEZONE=UTC

# Exercise routine (optional)
# Format: activity:days_per_week
# This gives Claude context about your training schedule
EXERCISE_DAYS_PER_WEEK=strength:4,yoga:7,cardio:2
